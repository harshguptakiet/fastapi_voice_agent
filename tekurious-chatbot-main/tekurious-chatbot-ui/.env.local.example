# Next.js server-side env vars (used by app/api route handlers)
# Copy to .env.local

# DarshanAI (Python service) base URL
# Local python default: http://localhost:8000
DARSHAN_AI_BASE_URL=http://127.0.0.1:8000

EDUTHUM_STUDENT_ID=2

# Unified FastAPI backend: /agent/stream, /voice/*, /documents/*
# Preferred: TEKURIOUS_FASTAPI_URL (production: https://your-alb-or-api — no :8001 in URL when behind HTTPS).
# Docker/ECS default container port is 8001; local uvicorn often uses 8010 — match your running backend.
TEKURIOUS_FASTAPI_URL=http://127.0.0.1:8010
TEKURIOUS_AI_BASE_URL=http://127.0.0.1:8010
EDUTHUM_BASE_URL=http://127.0.0.1:8010
FASTAPI_BASE_URL=http://127.0.0.1:8010
FASTAPI_VOICE_BASE_URL=http://127.0.0.1:8010
FASTAPI_TENANT_ID=tenant-demo
